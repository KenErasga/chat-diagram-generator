{
  "name": "chat-diagram-generator",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:app": "turbo run dev --filter=@repo/chat-app",
    "dev:service": "turbo run dev --filter=@repo/chat-service",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "latest",
    "typescript": "^5.3.3"
  }
}
